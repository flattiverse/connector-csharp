<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Version>0.0.1.15</Version>
        <AssemblyVersion>0.0.1.15</AssemblyVersion>
        <FileVersion>0.0.1.15</FileVersion>
        <PackageReadmeFile>NUGET_README.md</PackageReadmeFile>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
      <DocumentationFile>bin\Debug\Flattiverse.Connector.xml</DocumentationFile>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
      <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
      <DocumentationFile>bin\Release\Flattiverse.Connector.xml</DocumentationFile>
    </PropertyGroup>

    <ItemGroup>
      <None Include="..\..\NUGET_README.md" Pack="true" PackagePath="\" Link="NUGET_README.md" />
    </ItemGroup>

</Project>
